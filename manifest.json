{
  "id": "parallax-wallpaper",
  "name": "Parallax Wallpaper",
  "version": "1.1.0",
  "minNoctaliaVersion": "4.4.0",
  "author": "You",
  "license": "MIT",
  "description": "Adds a customizable parallax effect to the wallpaper based on the active workspace.",
  "tags": ["Background", "Visual"],
  "entryPoints": {
    "main": "Main.qml",
    "settings": "Settings.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "defaultSettings": {
      "zoomAmount": 1.1,
      "parallaxDirection": "horizontal",
      "hParallaxAmount": 50,
      "hParallaxDuration": 400,
      "vParallaxAmount": 50,
      "vParallaxDuration": 400,
      "invertDirection": false,
      "autoZoom": false,
      "parallaxEasing": "OutCubic"
    }
  }
}
